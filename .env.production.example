# ===========================================
# Variáveis de Ambiente para Produção
# ===========================================
# Copie este arquivo para .env e preencha os valores
# NÃO faça commit do arquivo .env no Git!

# ===========================================
# Database
# ===========================================
DB_PASSWORD=senha_forte_aqui

# ===========================================
# OCI Object Storage
# ===========================================
OCI_TENANCY_ID=ocid1.tenancy.oc1..xxxxxx
OCI_USER_ID=ocid1.user.oc1..xxxxxx
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_NAMESPACE=seu_namespace
# A chave privada deve estar em ./oci-key/api_key.pem no servidor

# ===========================================
# Aplicação
# ===========================================
APP_BASE_URL=https://hojeafestaenossa.site

# ===========================================
# Docker Deploy (opcional, se usar)
# ===========================================
DOCKPLOY_URL=http://localhost:3000
DOCKPLOY_API_KEY=sua_api_key
